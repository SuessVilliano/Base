# =============================================================================
# BASE — environment variables
# Copy to `.env.local` for local dev. In production, set these in
# Vercel → Project → Settings → Environment Variables.
# =============================================================================

# GoHighLevel Private Integration Token. Required for the /api/inquiry route
# to forward form submissions into GHL as contacts + notes.
# Create one at: Settings → Private Integrations → Create new integration
# Scopes needed: contacts.write, contacts.readonly
GHL_PIT_TOKEN=

# (Optional) Override the location ID baked into src/data/config.ts.
# Leave blank in most cases.
GHL_LOCATION_ID=
